<% content_for :title, "Setup inicial - DeepSoul" %>

<div class="mx-auto max-w-md px-4 py-16">
  <div class="rounded-2xl border border-arrecife bg-white p-8 shadow-xl">
    <h1 class="text-2xl font-bold text-abismo">Setup Inicial</h1>
    <p class="mt-4 text-sm text-profundo">
      No hay usuarios en el sistema. Haz clic en el botón para crear la agencia DeepSoul y el usuario administrador.
    </p>

    <%= form_with url: setup_path, method: :post, class: "mt-6" do |f| %>
      <%= f.submit "Crear agencia y usuario admin", class: "w-full rounded-xl bg-coral px-6 py-3 font-semibold text-white transition hover:bg-coral-hover" %>
    <% end %>

    <div class="mt-6 rounded-lg bg-oceano/10 p-4 text-sm">
      <p class="font-semibold text-abismo">Esto creará:</p>
      <ul class="mt-2 space-y-1 text-profundo">
        <li>• Agencia: DeepSoul</li>
        <li>• Email: admin@deepsoul.com</li>
        <li>• Password: ChangeMe2026!</li>
      </ul>
    </div>
  </div>
</div>
