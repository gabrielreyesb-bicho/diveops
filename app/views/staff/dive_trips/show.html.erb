<div class="mx-auto max-w-3xl space-y-6">
  <div class="overflow-hidden rounded-xl border border-arrecife/60 bg-white p-6 shadow-md ring-1 ring-arrecife/60 sm:p-8">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <h1 class="text-xl font-semibold text-profundo"><%= @dive_trip.title %></h1>
      <div class="flex flex-wrap gap-2 text-sm">
        <%= link_to "Editar", edit_staff_dive_trip_path(@dive_trip), class: "font-medium text-caribe underline decoration-caribe/40 hover:text-oceano" %>
        <%= button_to "Eliminar", staff_dive_trip_path(@dive_trip), method: :delete, form: { data: { turbo_confirm: "¿Eliminar este viaje?" } }, class: "text-red-700 underline" %>
      </div>
    </div>

    <dl class="mt-6 grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
      <dt class="text-abismo/70">Destino</dt>
      <dd class="text-abismo"><%= @dive_trip.destination %></dd>
      <dt class="text-abismo/70">Salida / Regreso</dt>
      <dd class="text-abismo"><%= @dive_trip.departure_date&.strftime("%Y-%m-%d") %> → <%= @dive_trip.return_date&.strftime("%Y-%m-%d") %></dd>
      <dt class="text-abismo/70">Cupos</dt>
      <dd class="text-abismo"><%= @dive_trip.min_capacity %> – <%= @dive_trip.max_capacity %></dd>
      <dt class="text-abismo/70">Precio base</dt>
      <dd class="text-abismo"><%= @dive_trip.base_price %></dd>
      <dt class="text-abismo/70">Estado</dt>
      <dd class="text-abismo"><%= program_status_text(@dive_trip) %></dd>
      <% if @dive_trip.cancellation_reason.present? %>
        <dt class="text-abismo/70">Motivo cancelación</dt>
        <dd class="text-abismo"><%= @dive_trip.cancellation_reason %></dd>
      <% end %>
    </dl>

    <section class="mt-8">
      <h2 class="text-sm font-medium text-profundo">Descripción</h2>
      <div class="trix-content mt-2 rounded-lg border border-arrecife/50 bg-espuma/30 p-3 text-sm text-abismo"><%= @dive_trip.description %></div>
    </section>
    <section class="mt-6">
      <h2 class="text-sm font-medium text-profundo">Requisitos</h2>
      <div class="trix-content mt-2 rounded-lg border border-arrecife/50 bg-espuma/30 p-3 text-sm text-abismo"><%= @dive_trip.requirements %></div>
    </section>
    <section class="mt-6">
      <h2 class="text-sm font-medium text-profundo">Itinerario</h2>
      <div class="trix-content mt-2 rounded-lg border border-arrecife/50 bg-espuma/30 p-3 text-sm text-abismo"><%= @dive_trip.itinerary %></div>
    </section>

    <p class="mt-6 text-sm">
      <%= link_to "Inscripciones de este viaje", staff_dive_trip_registrations_path(@dive_trip), class: "font-medium text-caribe underline decoration-caribe/40 hover:text-oceano" %>
    </p>

    <section class="mt-8">
      <h2 class="text-sm font-medium text-profundo">Fotos</h2>
      <% if @dive_trip.photos.any? %>
        <ul class="mt-3 space-y-3">
          <% @dive_trip.photos.order(:position).each do |photo| %>
            <li class="flex flex-wrap items-center gap-3">
              <% if photo.image.attached? %>
                <%= image_tag photo.image.variant(resize_to_limit: [ 400, 400 ]), class: "max-h-40 rounded-lg border border-arrecife/50" %>
              <% end %>
              <%= button_to "Eliminar foto", staff_dive_trip_photo_path(@dive_trip, photo), method: :delete, form: { data: { turbo_confirm: "¿Eliminar esta foto?" } }, class: "text-sm text-red-700 underline" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-2 text-sm text-slate-600">Sin fotos.</p>
      <% end %>
    </section>

    <section class="mt-8 rounded-lg border border-arrecife/50 bg-espuma/40 p-4">
      <h2 class="text-sm font-medium text-profundo">Cambiar estado</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        <% if @dive_trip.program_planning? %>
          <%= button_to "Publicar (abierto)", publish_staff_dive_trip_path(@dive_trip), method: :post, class: "rounded bg-oceano px-3 py-1.5 text-sm font-medium text-white hover:bg-profundo" %>
        <% end %>
        <% if @dive_trip.program_pending_confirmation? %>
          <%= button_to "Confirmar programa", confirm_staff_dive_trip_path(@dive_trip), method: :post, class: "rounded bg-coral px-3 py-1.5 text-sm font-medium text-white hover:bg-coral-hover" %>
        <% end %>
      </div>

      <% unless @dive_trip.program_cancelled? %>
        <%= form_with url: cancel_staff_dive_trip_path(@dive_trip), method: :post, local: true, class: "mt-4 space-y-2" do %>
          <label class="block text-sm text-abismo/80">Cancelar programa (indica motivo)</label>
          <%= text_area_tag :cancellation_reason, nil, rows: 2, class: "w-full rounded-lg border border-slate-300 bg-white px-2 py-1.5 text-sm", placeholder: "Motivo visible para el equipo" %>
          <%= submit_tag "Cancelar programa", class: "rounded bg-red-700 px-3 py-1.5 text-sm text-white hover:bg-red-800" %>
        <% end %>
      <% end %>
    </section>
  </div>

  <p>
    <%= link_to "← Lista de viajes", staff_dive_trips_path, class: "text-sm font-medium text-caribe underline decoration-caribe/40 hover:text-oceano" %>
  </p>
</div>
