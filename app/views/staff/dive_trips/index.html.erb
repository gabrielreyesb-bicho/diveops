<div class="mx-auto max-w-5xl">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <h1 class="text-xl font-semibold text-profundo">Viajes de buceo</h1>
    <%= link_to "Nuevo viaje", new_staff_dive_trip_path, class: "inline-flex items-center justify-center rounded-lg border-2 border-oceano bg-white px-4 py-2 text-sm font-medium text-oceano shadow-sm transition hover:bg-espuma hover:text-profundo", data: { turbo: false } %>
  </div>

  <div class="mt-6 overflow-hidden rounded-xl border border-arrecife/60 bg-white shadow-md ring-1 ring-arrecife/60">
    <% if @dive_trips.any? %>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[640px] border-collapse text-left text-sm">
          <thead>
            <tr class="border-b border-arrecife bg-espuma/90 text-xs font-semibold uppercase tracking-wide text-profundo">
              <th scope="col" class="whitespace-nowrap px-4 py-3">Nombre</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3">Destino</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3">Salida</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3">Regreso</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3">Estado</th>
              <th scope="col" class="px-4 py-3"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-arrecife/50">
            <% @dive_trips.each do |trip| %>
              <tr class="bg-white transition hover:bg-espuma/50">
                <td class="px-4 py-3 font-medium text-abismo"><%= trip.title %></td>
                <td class="max-w-[12rem] truncate px-4 py-3 text-abismo/90" title="<%= trip.destination %>"><%= trip.destination %></td>
                <td class="whitespace-nowrap px-4 py-3 text-abismo/90"><%= trip.departure_date&.strftime("%Y-%m-%d") %></td>
                <td class="whitespace-nowrap px-4 py-3 text-abismo/90"><%= trip.return_date&.strftime("%Y-%m-%d") %></td>
                <td class="whitespace-nowrap px-4 py-3 text-abismo/90"><%= program_status_text(trip) %></td>
                <td class="whitespace-nowrap px-4 py-3">
                  <%= link_to "Ver", staff_dive_trip_path(trip), class: "font-medium text-caribe underline decoration-caribe/40 hover:text-oceano" %>
                  <span class="text-arrecife" aria-hidden="true"> · </span>
                  <%= link_to "Editar", edit_staff_dive_trip_path(trip), class: "font-medium text-caribe underline decoration-caribe/40 hover:text-oceano" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="px-6 py-12 text-center text-sm text-slate-600">No hay viajes todavía. <%= link_to "Crear el primero", new_staff_dive_trip_path, class: "font-medium text-oceano underline hover:text-profundo" %>.</p>
    <% end %>
  </div>

  <p class="mt-8">
    <%= link_to "← Panel", staff_root_path, class: "text-sm font-medium text-caribe underline decoration-caribe/40 hover:text-oceano" %>
  </p>
</div>
