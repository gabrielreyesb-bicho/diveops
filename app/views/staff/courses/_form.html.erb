<%= form_with model: [:staff, course],
              html: { class: "space-y-4 w-full", multipart: true, novalidate: true },
              data: { turbo: false } do |f| %>
  <% if course.errors.any? %>
    <div class="rounded border border-red-300 bg-red-50 p-3 text-sm text-red-800">
      <ul class="list-disc pl-5">
        <% course.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Nombre del curso", class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :title, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
  </div>

  <div>
    <%= f.label :certification_granted, "Certificación que otorga", class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :certification_granted, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
  </div>

  <div>
    <%= f.label :prerequisite_certification, "Certificación mínima requerida", class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :prerequisite_certification, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :start_date, "Fecha de inicio", class: "block text-sm font-medium text-slate-700" %>
      <%= f.date_field :start_date, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
    </div>
    <div>
      <%= f.label :end_date, "Fecha de término", class: "block text-sm font-medium text-slate-700" %>
      <%= f.date_field :end_date, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
    </div>
  </div>

  <div>
    <%= f.label :duration_description, "Duración (días/horas)", class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :duration_description, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :min_capacity, "Cupo mínimo (quorum)", class: "block text-sm font-medium text-slate-700" %>
      <%= f.number_field :min_capacity, min: 1, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
    </div>
    <div>
      <%= f.label :max_capacity, "Cupo máximo", class: "block text-sm font-medium text-slate-700" %>
      <%= f.number_field :max_capacity, min: 1, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
    </div>
  </div>

  <div>
    <%= f.label :base_price, "Precio base", class: "block text-sm font-medium text-slate-700" %>
    <%= f.number_field :base_price, min: 0, step: "0.01", class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
  </div>

  <div>
    <%= f.label :status, "Estado", class: "block text-sm font-medium text-slate-700" %>
    <%= f.select :status, Course.statuses.keys.map { |k| [ t("activerecord.enums.course.status.#{k}", default: k.to_s.humanize), k ] }, {}, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
  </div>

  <div>
    <%= f.label :description, "Descripción", class: "block text-sm font-medium text-slate-700" %>
    <%= f.rich_text_area :description, class: "mt-1 w-full" %>
  </div>

  <div>
    <%= f.label :cancellation_reason, "Motivo de cancelación (si aplica)", class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_area :cancellation_reason, rows: 2, class: "mt-1 w-full rounded border border-slate-300 px-2 py-1" %>
  </div>

  <div data-controller="multi-file-preview">
    <% if course.persisted? %>
      <% saved_photos = course.photos.includes(image_attachment: :blob).order(:position).select { |p| p.image.attached? } %>
      <% if saved_photos.any? %>
        <div class="mb-4">
          <span class="block text-sm font-medium text-slate-700">Fotos guardadas</span>
          <p class="mt-1 text-xs text-slate-500">Las nuevas imágenes que elijas se sumarán al guardar.</p>
          <ul class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4" role="list">
            <% saved_photos.each do |photo| %>
              <li class="overflow-hidden rounded-lg border border-caribe/60 bg-white shadow-sm ring-1 ring-caribe/40">
                <%= image_tag photo.image.variant(resize_to_limit: [160, 160]), class: "h-28 w-full object-cover", alt: "" %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    <% end %>

    <span class="block text-sm font-medium text-slate-700"><%= course.persisted? ? "Añadir más fotos" : "Añadir fotos" %></span>
    <div class="mt-2">
      <label class="inline-flex w-fit cursor-pointer items-center justify-center gap-2 rounded-lg border-2 border-caribe bg-white px-4 py-2 text-sm font-medium text-caribe shadow-sm transition hover:bg-espuma hover:text-profundo focus-within:outline focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-caribe">
        <%= f.file_field :images,
                         multiple: true,
                         accept: "image/*",
                         class: "sr-only",
                         data: {
                           multi_file_preview_target: "input",
                           action: "change->multi-file-preview#preview"
                         },
                         aria: { describedby: "staff_course_images_hint" } %>
        <span aria-hidden="true">Elegir imágenes</span>
      </label>
    </div>
    <p id="staff_course_images_hint" class="mt-2 text-xs text-slate-500">Puedes seleccionar varias imágenes (JPEG, PNG, etc.).</p>
    <div data-multi-file-preview-target="list" class="min-h-0"></div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit course.new_record? ? "Crear curso" : "Guardar cambios", class: "rounded bg-profundo px-4 py-2 text-sm font-medium text-espuma hover:bg-abismo" %>
    <%= link_to "Cancelar", course.new_record? ? staff_courses_path : staff_course_path(course), class: "rounded border border-slate-300 px-4 py-2 text-sm" %>
  </div>
<% end %>
