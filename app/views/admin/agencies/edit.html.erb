<% content_for :title, "Editar #{@agency.name} · Plataforma DiveOps" %>

<div class="mx-auto max-w-lg space-y-6">
  <div>
    <h1 class="text-xl font-semibold text-profundo">Editar agencia</h1>
    <p class="mt-1 font-mono text-sm text-abismo/80"><%= @agency.slug %></p>
  </div>

  <%= render "form", agency: @agency %>

  <p class="text-center text-sm">
    <%= link_to "Ver ficha", admin_agency_path(@agency), class: "font-medium text-caribe underline decoration-caribe/40 hover:text-oceano" %>
    ·
    <%= link_to "Todas las agencias", admin_agencies_path, class: "font-medium text-caribe underline decoration-caribe/40 hover:text-oceano" %>
  </p>
</div>
