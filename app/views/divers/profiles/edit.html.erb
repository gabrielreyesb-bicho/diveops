<% content_for :title, "Editar perfil · DiveOps" %>

<div class="mx-auto max-w-xl">
  <div class="overflow-hidden rounded-xl border border-arrecife/60 bg-white p-6 shadow-md ring-1 ring-arrecife/60 sm:p-8">
    <h1 class="text-xl font-semibold text-profundo">Editar perfil</h1>

    <%= form_with model: current_diver, url: diver_profile_path, method: :patch, html: { class: "mt-6 space-y-5", multipart: true } do |f| %>
      <% if current_diver.errors.any? %>
        <div class="rounded border border-coral bg-coral/10 p-3 text-sm text-abismo">
          <ul class="list-disc pl-5">
            <% current_diver.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :avatar, "Foto de perfil", class: "block text-sm font-medium text-slate-700" %>
        <div class="mt-2 flex flex-wrap items-center gap-4">
          <%= diver_avatar_for(current_diver, variant: :md) %>
          <%= f.file_field :avatar, accept: "image/*", class: "block w-full text-sm text-slate-600 file:mr-3 file:rounded file:border-0 file:bg-espuma file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-oceano hover:file:bg-arrecife/40" %>
        </div>
        <% if current_diver.avatar.attached? %>
          <label class="mt-2 flex items-center gap-2 text-sm text-slate-600">
            <%= check_box_tag :remove_avatar, "1", false, class: "rounded border-slate-300" %>
            Quitar foto actual
          </label>
        <% end %>
      </div>

      <div>
        <%= f.label :name, "Nombre", class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :name, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= f.label :dive_count, "Número de inmersiones", class: "block text-sm font-medium text-slate-700" %>
        <%= f.number_field :dive_count, min: 0, step: 1, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
        <p class="mt-1 text-xs text-slate-500">Podés dejarlo vacío si preferís no indicarlo.</p>
      </div>

      <div>
        <%= f.label :certification_level, "Nivel de certificación", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :certification_level,
                     Diver.certification_levels.keys.map { |k|
                       [ I18n.t("activerecord.enums.diver.certification_level.#{k}", default: k.to_s.humanize), k ]
                     },
                     {},
                     class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      </div>

      <div class="rounded-lg border border-slate-200 bg-slate-50/80 p-4">
        <label class="flex cursor-pointer gap-3">
          <%= f.check_box :receive_diveops_emails, class: "mt-1 rounded border-slate-300" %>
          <span>
            <span class="block text-sm font-medium text-abismo">Correos de DiveOps</span>
            <span class="mt-1 block text-xs text-slate-600">
              Recibir avisos sobre tu cuenta, inscripciones y programas. Los correos necesarios por seguridad (por ejemplo, restablecer contraseña) pueden enviarse igual.
            </span>
          </span>
        </label>
      </div>

      <fieldset>
        <legend class="text-sm font-medium text-slate-700">Privacidad del perfil</legend>
        <p class="mt-1 text-xs text-slate-500">Define quién puede verte en el listado “quién va” de cada programa.</p>
        <div class="mt-3 space-y-4">
          <% Diver.privacies.each_key do |key| %>
            <label class="flex cursor-pointer gap-3 rounded-lg border border-slate-200 p-3 has-[:checked]:border-oceano has-[:checked]:bg-espuma/50">
              <%= f.radio_button :privacy, key, class: "mt-1" %>
              <span>
                <span class="block text-sm font-medium text-abismo"><%= I18n.t("activerecord.enums.diver.privacy.#{key}") %></span>
                <span class="mt-1 block text-xs text-slate-600"><%= I18n.t("diver.privacy_help.#{key}", default: "") %></span>
              </span>
            </label>
          <% end %>
        </div>
      </fieldset>

      <div class="flex flex-wrap gap-3 pt-2">
        <%= f.submit "Guardar cambios", class: "rounded-lg bg-oceano px-4 py-2 text-sm font-medium text-white hover:bg-profundo" %>
        <%= link_to "Cancelar", diver_profile_path, class: "rounded-lg border border-slate-300 px-4 py-2 text-sm text-abismo hover:bg-slate-50" %>
      </div>
    <% end %>

    <% unless current_diver.provider_google? %>
      <p class="mt-8 border-t border-arrecife/40 pt-6 text-sm text-slate-600">
        ¿Necesitás cambiar tu contraseña?
        <%= link_to "Cambiar contraseña", edit_diver_profile_password_path, class: "font-medium text-caribe underline hover:text-oceano" %>
      </p>
    <% end %>
  </div>
</div>
