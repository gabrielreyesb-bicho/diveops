<% content_for :title, "Nueva contraseña — buzos · DiveOps" %>
<% content_for :auth_tagline, "Elige una contraseña segura para tu cuenta." %>

<div class="space-y-2 text-center">
  <p class="inline-flex rounded-full bg-arrecife/50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-abismo">Buzo</p>
  <h1 class="<%= auth_card_title_class %>">Establecer contraseña</h1>
</div>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "mt-8 space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div>
    <%= f.label :password, "Nueva contraseña", class: auth_label_class %>
    <% if @minimum_password_length %>
      <span class="text-xs text-slate-500">(mínimo <%= @minimum_password_length %> caracteres)</span>
    <% end %>
    <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: auth_input_class %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirmar contraseña", class: auth_label_class %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: auth_input_class %>
  </div>

  <div>
    <%= f.submit "Guardar contraseña", class: "w-full cursor-pointer rounded-xl bg-coral px-4 py-3 text-sm font-semibold text-white shadow-md transition hover:bg-coral-hover focus:outline-none focus:ring-2 focus:ring-oceano focus:ring-offset-2" %>
  </div>
<% end %>
