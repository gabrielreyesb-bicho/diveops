<% content_for :title, "Cambiar contraseña · DiveOps" %>

<div class="mx-auto max-w-md">
  <div class="overflow-hidden rounded-xl border border-arrecife/60 bg-white p-6 shadow-md ring-1 ring-arrecife/60 sm:p-8">
    <h1 class="text-xl font-semibold text-profundo">Cambiar contraseña</h1>
    <p class="mt-2 text-sm text-slate-600">Ingresá tu contraseña actual y elegí una nueva.</p>

    <%= form_with model: current_diver, url: profile_password_path, method: :patch, html: { class: "mt-6 space-y-4" } do |f| %>
      <% if current_diver.errors.any? %>
        <div class="rounded border border-coral bg-coral/10 p-3 text-sm text-abismo">
          <ul class="list-disc pl-5">
            <% current_diver.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :current_password, "Contraseña actual", class: "block text-sm font-medium text-slate-700" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= f.label :password, "Nueva contraseña", class: "block text-sm font-medium text-slate-700" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmar nueva contraseña", class: "block text-sm font-medium text-slate-700" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <%= f.submit "Actualizar contraseña", class: "rounded-lg bg-oceano px-4 py-2 text-sm font-medium text-white hover:bg-profundo" %>
        <%= link_to "Volver al perfil", diver_profile_path, class: "rounded-lg border border-slate-300 px-4 py-2 text-sm text-abismo hover:bg-slate-50" %>
      </div>
    <% end %>
  </div>
</div>
