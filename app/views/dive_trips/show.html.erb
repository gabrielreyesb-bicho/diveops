<div class="mx-auto max-w-4xl">
  <div class="overflow-hidden rounded-xl border border-arrecife/60 bg-white p-6 shadow-md ring-1 ring-arrecife/60 sm:p-8">
  <% my_registration = diver_signed_in? ? current_diver.registrations.find_by(program: @dive_trip) : nil %>
  <div class="mb-8 border-b border-arrecife/50 pb-8">
    <p class="text-sm text-slate-500"><%= link_to "Catálogo", programs_path, class: "text-caribe underline" %> · Viaje de buceo</p>
    <h1 class="mt-2 text-2xl font-semibold text-profundo"><%= @dive_trip.title %></h1>
    <span class="mt-2 inline-block rounded px-2 py-0.5 text-xs font-medium <%= program_status_badge_class(@dive_trip.status) %>">
      <%= program_status_text(@dive_trip) %>
    </span>

    <% if my_registration %>
      <div class="mt-6 flex flex-col gap-6 md:flex-row md:items-start md:gap-x-12 md:gap-y-0 lg:gap-x-16">
        <div class="min-w-0 flex-1">
          <dl class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2 sm:gap-x-4">
            <dt class="text-slate-500">Destino</dt>
            <dd class="min-w-0 break-words"><%= @dive_trip.destination %></dd>
            <dt class="text-slate-500">Salida / Regreso</dt>
            <dd><%= @dive_trip.departure_date&.strftime("%Y-%m-%d") %> → <%= @dive_trip.return_date&.strftime("%Y-%m-%d") %></dd>
            <dt class="text-slate-500">Cupos</dt>
            <dd><%= @dive_trip.min_capacity %> – <%= @dive_trip.max_capacity %></dd>
            <dt class="text-slate-500">Precio base</dt>
            <dd><%= @dive_trip.base_price.present? ? number_to_currency(@dive_trip.base_price, unit: "$", precision: 2) : "—" %></dd>
          </dl>
        </div>
        <aside class="w-full shrink-0 md:max-w-[16rem] lg:max-w-[17.5rem]">
          <%= render "programs/diver_program_enrollment", program: @dive_trip, registration: my_registration %>
        </aside>
      </div>
    <% else %>
      <dl class="mt-6 grid gap-2 text-sm sm:grid-cols-2">
        <dt class="text-slate-500">Destino</dt>
        <dd><%= @dive_trip.destination %></dd>
        <dt class="text-slate-500">Salida / Regreso</dt>
        <dd><%= @dive_trip.departure_date&.strftime("%Y-%m-%d") %> → <%= @dive_trip.return_date&.strftime("%Y-%m-%d") %></dd>
        <dt class="text-slate-500">Cupos</dt>
        <dd><%= @dive_trip.min_capacity %> – <%= @dive_trip.max_capacity %></dd>
        <dt class="text-slate-500">Precio base</dt>
        <dd><%= @dive_trip.base_price.present? ? number_to_currency(@dive_trip.base_price, unit: "$", precision: 2) : "—" %></dd>
      </dl>
    <% end %>
  </div>

  <section class="mt-8">
    <h2 class="text-sm font-medium text-slate-700">Descripción</h2>
    <div class="trix-content mt-2 border border-slate-200 p-3 text-sm"><%= @dive_trip.description %></div>
  </section>

  <section class="mt-8">
    <h2 class="text-sm font-medium text-slate-700">Requisitos</h2>
    <div class="trix-content mt-2 border border-slate-200 p-3 text-sm"><%= @dive_trip.requirements %></div>
  </section>

  <section class="mt-8">
    <h2 class="text-sm font-medium text-slate-700">Itinerario</h2>
    <div class="trix-content mt-2 border border-slate-200 p-3 text-sm"><%= @dive_trip.itinerary %></div>
  </section>

  <% if @dive_trip.photos.any? { |p| program_image_usable?(p.image) } %>
    <section class="mt-8">
      <h2 class="text-sm font-medium text-slate-700">Galería</h2>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <% @dive_trip.photos.order(:position).each do |photo| %>
          <% next unless program_image_usable?(photo.image) %>
          <% src = photo.image.variable? ? photo.image.variant(resize_to_fill: [ 1600, 900 ]) : photo.image %>
          <div class="aspect-video w-full overflow-hidden rounded-xl border border-arrecife/50 bg-espuma shadow-sm ring-1 ring-arrecife/30">
            <%= image_tag src, class: "h-full w-full object-cover", alt: "" %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <%= render "programs/going_divers", going: @going_divers, program_label: "este viaje" %>

  <section class="mt-8 flex flex-col gap-3 border-t border-slate-200 pt-6">
    <% if diver_signed_in? %>
      <% unless my_registration %>
        <% if program_accepts_self_registration?(@dive_trip) %>
          <%= button_to "Inscribirse", register_trip_path(@dive_trip), method: :post, class: "w-fit rounded bg-coral px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-coral-hover" %>
        <% else %>
          <p class="text-sm text-slate-600">Inscripciones no disponibles para el estado actual del programa.</p>
        <% end %>
      <% end %>
      <p class="text-sm"><%= link_to "Mis inscripciones", my_registrations_path, class: "text-caribe underline" %></p>
    <% else %>
      <%= link_to "Me interesa", catalog_signup_path_for_actions, class: "w-fit rounded border border-slate-300 bg-white px-4 py-2 text-sm" %>
      <%= link_to "Crear cuenta e inscribirse", catalog_signup_path_for_actions, class: "w-fit rounded bg-coral px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-coral-hover" %>
      <p class="text-xs text-slate-500">Necesitas una cuenta de buzo para inscribirte.</p>
    <% end %>
  </section>
  </div>
</div>
