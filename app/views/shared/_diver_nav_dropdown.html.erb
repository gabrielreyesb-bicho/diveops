<div
  class="relative shrink-0"
  data-controller="dropdown"
  data-action="click@window->dropdown#closeOnClickOutside keydown@window->dropdown#closeOnEscape"
>
  <button
    type="button"
    class="inline-flex max-w-[min(100%,18rem)] items-center gap-2 rounded-lg px-2 py-1.5 text-left text-sm font-medium text-white transition hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/60"
    data-action="click->dropdown#toggle"
    aria-expanded="false"
    aria-haspopup="menu"
    aria-label="<%= h("Menú de cuenta (#{current_diver.name})") %>"
  >
    <span class="min-w-0 truncate"><%= current_diver.name %></span>
    <svg class="h-4 w-4 shrink-0 opacity-80" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>
  <div
    data-dropdown-target="panel"
    class="hidden max-h-[min(24rem,70dvh)] min-w-[12rem] overflow-y-auto rounded-lg border border-abismo/20 bg-white py-1 text-sm text-abismo shadow-lg ring-1 ring-abismo/10"
    role="menu"
    aria-hidden="true"
  >
    <%= link_to "Mi perfil", diver_profile_path, class: "block px-4 py-2 text-abismo no-underline hover:bg-espuma", role: "menuitem" %>
    <%= link_to "Mis inscripciones", my_registrations_path, class: "block px-4 py-2 text-abismo no-underline hover:bg-espuma", role: "menuitem" %>
    <%= link_to "Cerrar sesión",
                destroy_diver_session_path,
                data: { turbo_method: :delete },
                class: "block w-full px-4 py-2 text-left text-abismo no-underline hover:bg-espuma",
                role: "menuitem" %>
  </div>
</div>
