<div
  class="relative shrink-0"
  data-controller="dropdown"
  data-action="click@window->dropdown#closeOnClickOutside keydown@window->dropdown#closeOnEscape"
>
  <button
    type="button"
    class="inline-flex shrink-0 items-center gap-0 rounded-full transition hover:ring-2 hover:ring-abismo/40 focus:outline-none focus-visible:ring-2 focus-visible:ring-abismo/60"
    data-action="click->dropdown#toggle"
    aria-expanded="false"
    aria-haspopup="menu"
    aria-label="<%= h("Menú de cuenta (#{current_user.name})") %>"
  >
    <%= user_avatar_for(current_user, variant: :nav) %>
  </button>
  <div
    data-dropdown-target="panel"
    class="absolute right-0 top-full mt-2 hidden max-h-[min(24rem,70dvh)] min-w-[12rem] overflow-y-auto rounded-lg border border-abismo/20 bg-white py-1 text-sm text-abismo shadow-lg ring-1 ring-abismo/10"
    role="menu"
    aria-hidden="true"
  >
    <%= link_to "Panel agencia", staff_root_path, class: "block px-4 py-2 text-abismo no-underline hover:bg-espuma", role: "menuitem" %>
    <%= link_to "Cerrar sesión",
                destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "block w-full px-4 py-2 text-left text-abismo no-underline hover:bg-espuma",
                role: "menuitem" %>
  </div>
</div>
