<% content_for :title, "Recuperar contraseña — staff · DiveOps" %>
<% content_for :auth_tagline, "Te enviaremos un enlace para restablecerla." %>

<div class="space-y-2 text-center">
  <p class="inline-flex rounded-full bg-arrecife/50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-abismo">Staff</p>
  <h1 class="<%= auth_card_title_class %>">¿Olvidaste tu contraseña?</h1>
  <p class="<%= auth_muted_class %>">Indica el correo de tu cuenta de agencia</p>
</div>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-8 space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div>
    <%= f.label :email, "Correo electrónico", class: auth_label_class %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: auth_input_class, placeholder: "tu@agencia.com" %>
  </div>

  <div>
    <%= f.submit "Enviar instrucciones", class: "w-full cursor-pointer rounded-xl bg-coral px-4 py-3 text-sm font-semibold text-white shadow-md transition hover:bg-coral-hover focus:outline-none focus:ring-2 focus:ring-oceano focus:ring-offset-2" %>
  </div>
<% end %>

<p class="mt-8 text-center text-sm">
  <%= link_to "Volver al inicio de sesión", new_session_path(resource_name), class: auth_secondary_link_class %>
</p>
