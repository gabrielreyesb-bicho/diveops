<% content_for :title, "Alta de staff · DiveOps" %>
<% content_for :auth_tagline, "Asocia tu cuenta a una agencia existente en DiveOps." %>

<div class="space-y-2 text-center">
  <p class="inline-flex rounded-full bg-arrecife/50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-abismo">Staff</p>
  <h1 class="<%= auth_card_title_class %>">Crear cuenta</h1>
  <p class="<%= auth_muted_class %>">Necesitas una agencia en el sistema. Si no hay ninguna, en consola: <code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-800">bin/rails db:seed</code></p>
</div>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div>
    <%= f.label :email, "Correo electrónico", class: auth_label_class %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: auth_input_class, placeholder: "tu@agencia.com" %>
  </div>

  <div>
    <%= f.label :name, "Nombre", class: auth_label_class %>
    <%= f.text_field :name, autocomplete: "name", class: auth_input_class %>
  </div>

  <div>
    <%= f.label :agency_id, "Agencia", class: auth_label_class %>
    <%= f.collection_select :agency_id, Agency.order(:name), :id, :name, { prompt: "Selecciona una agencia" }, { class: auth_select_class, required: true } %>
  </div>

  <div>
    <%= f.label :password, "Contraseña", class: auth_label_class %>
    <% if @minimum_password_length %>
      <span class="text-xs text-slate-500">(mínimo <%= @minimum_password_length %> caracteres)</span>
    <% end %>
    <%= f.password_field :password, autocomplete: "new-password", class: auth_input_class %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirmar contraseña", class: auth_label_class %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: auth_input_class %>
  </div>

  <div>
    <%= f.submit "Registrarse", class: "w-full cursor-pointer rounded-xl bg-coral px-4 py-3 text-sm font-semibold text-white shadow-md transition hover:bg-coral-hover focus:outline-none focus:ring-2 focus:ring-oceano focus:ring-offset-2" %>
  </div>
<% end %>

<p class="mt-8 text-center text-sm">
  ¿Ya tienes cuenta?
  <%= link_to "Iniciar sesión", new_session_path(resource_name), class: auth_secondary_link_class %>
</p>
