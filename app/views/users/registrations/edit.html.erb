<% content_for :title, "Editar cuenta · DiveOps" %>
<% content_for :auth_tagline, "Actualiza tu perfil de staff." %>

<div class="space-y-2 text-center">
  <p class="inline-flex rounded-full bg-arrecife/50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-abismo">Staff</p>
  <h1 class="<%= auth_card_title_class %>">Tu cuenta</h1>
  <p class="<%= auth_muted_class %>">Correo, nombre y contraseña</p>
</div>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "mt-8 space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div>
    <%= f.label :email, "Correo electrónico", class: auth_label_class %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: auth_input_class %>
  </div>

  <div>
    <%= f.label :name, "Nombre", class: auth_label_class %>
    <%= f.text_field :name, autocomplete: "name", class: auth_input_class %>
  </div>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <p class="rounded-lg bg-amber-50 px-3 py-2 text-sm text-amber-900">Esperando confirmación de: <%= resource.unconfirmed_email %></p>
  <% end %>

  <div>
    <%= f.label :password, "Nueva contraseña", class: auth_label_class %>
    <span class="text-xs text-slate-500">(dejar en blanco si no quieres cambiarla)</span>
    <%= f.password_field :password, autocomplete: "new-password", class: auth_input_class %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirmar nueva contraseña", class: auth_label_class %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: auth_input_class %>
  </div>

  <div>
    <%= f.label :current_password, "Contraseña actual", class: auth_label_class %>
    <span class="text-xs text-slate-500">(necesaria para guardar cambios)</span>
    <%= f.password_field :current_password, autocomplete: "current-password", class: auth_input_class %>
  </div>

  <div>
    <%= f.submit "Actualizar", class: "w-full cursor-pointer rounded-xl bg-coral px-4 py-3 text-sm font-semibold text-white shadow-md transition hover:bg-coral-hover focus:outline-none focus:ring-2 focus:ring-oceano focus:ring-offset-2" %>
  </div>
<% end %>

<p class="mt-8 text-center text-sm">
  <%= link_to "Volver al panel", staff_root_path, class: auth_secondary_link_class %>
</p>
