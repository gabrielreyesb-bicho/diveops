<% content_for :title, "Mi perfil · DiveOps" %>

<div class="mx-auto max-w-2xl">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-abismo">Mi perfil</h1>
    <p class="mt-2 text-sm text-profundo">Actualiza tu información personal y contraseña</p>
  </div>

  <div class="rounded-xl border border-arrecife bg-white p-6 shadow-md">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "Correo electrónico", class: "block text-sm font-medium text-abismo" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full rounded-lg border border-arrecife/40 px-3 py-2 text-sm focus:border-oceano focus:outline-none focus:ring-1 focus:ring-oceano" %>
      </div>

      <div>
        <%= f.label :name, "Nombre", class: "block text-sm font-medium text-abismo" %>
        <%= f.text_field :name, autocomplete: "name", class: "mt-1 block w-full rounded-lg border border-arrecife/40 px-3 py-2 text-sm focus:border-oceano focus:outline-none focus:ring-1 focus:ring-oceano" %>
      </div>

      <div>
        <%= f.label :avatar, "Foto de perfil", class: "block text-sm font-medium text-abismo" %>
        <div class="mt-2 flex items-center gap-4">
          <%= user_avatar_for(resource, variant: :md) %>
          <%= f.file_field :avatar, accept: "image/*", class: "text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-oceano file:text-white hover:file:bg-profundo file:cursor-pointer" %>
        </div>
        <p class="mt-1 text-xs text-slate-500">Formatos: JPG, PNG. Tamaño máximo: 5MB</p>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="rounded-lg bg-amber-50 px-3 py-2 text-sm text-amber-900">
          Esperando confirmación de: <%= resource.unconfirmed_email %>
        </div>
      <% end %>

      <div class="border-t border-arrecife/20 pt-5">
        <h3 class="text-sm font-semibold text-abismo">Cambiar contraseña</h3>
        <p class="mt-1 text-xs text-slate-500">Deja estos campos en blanco si no quieres cambiar tu contraseña</p>
      </div>

      <div>
        <%= f.label :password, "Nueva contraseña", class: "block text-sm font-medium text-abismo" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 block w-full rounded-lg border border-arrecife/40 px-3 py-2 text-sm focus:border-oceano focus:outline-none focus:ring-1 focus:ring-oceano" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmar nueva contraseña", class: "block text-sm font-medium text-abismo" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full rounded-lg border border-arrecife/40 px-3 py-2 text-sm focus:border-oceano focus:outline-none focus:ring-1 focus:ring-oceano" %>
      </div>

      <div>
        <%= f.label :current_password, "Contraseña actual", class: "block text-sm font-medium text-abismo" %>
        <p class="mt-1 text-xs text-slate-500">Solo necesaria si estás cambiando tu contraseña</p>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "mt-1 block w-full rounded-lg border border-arrecife/40 px-3 py-2 text-sm focus:border-oceano focus:outline-none focus:ring-1 focus:ring-oceano" %>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Guardar cambios", class: "flex-1 cursor-pointer rounded-xl bg-coral px-4 py-3 text-sm font-semibold text-white shadow-md transition hover:bg-coral-hover focus:outline-none focus:ring-2 focus:ring-oceano focus:ring-offset-2" %>
        <%= link_to "Cancelar", staff_root_path, class: "rounded-xl border border-arrecife/40 px-4 py-3 text-sm font-semibold text-abismo transition hover:bg-espuma" %>
      </div>
    <% end %>
  </div>
</div>
