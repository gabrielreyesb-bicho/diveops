<% content_for :title, "Iniciar sesión — staff · DiveOps" %>
<% content_for :auth_tagline, "Panel de agencia: gestiona salidas, cursos e inscripciones." %>

<div class="space-y-2 text-center">
  <p class="inline-flex rounded-full bg-arrecife/50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-abismo">Staff</p>
  <h1 class="<%= auth_card_title_class %>">Iniciar sesión</h1>
  <p class="<%= auth_muted_class %>">Acceso para el equipo de tu agencia</p>
</div>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div>
    <%= f.label :email, "Correo electrónico", class: auth_label_class %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: auth_input_class, placeholder: "tu@agencia.com" %>
  </div>

  <div>
    <%= f.label :password, "Contraseña", class: auth_label_class %>
    <%= f.password_field :password, autocomplete: "current-password", class: auth_input_class %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="flex items-center gap-2">
      <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-oceano focus:ring-oceano" %>
      <%= f.label :remember_me, "Recordarme en este equipo", class: "text-sm text-slate-600" %>
    </div>
  <% end %>

  <div>
    <%= f.submit "Entrar", class: "w-full cursor-pointer rounded-xl bg-coral px-4 py-3 text-sm font-semibold text-white shadow-md transition hover:bg-coral-hover focus:outline-none focus:ring-2 focus:ring-oceano focus:ring-offset-2" %>
  </div>
<% end %>

<div class="mt-8 space-y-3 border-t border-slate-200 pt-6 text-center text-sm">
  <p>
    <%= link_to "Crear cuenta de staff", new_registration_path(resource_name), class: auth_secondary_link_class %>
  </p>
  <p>
    <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name), class: auth_secondary_link_class %>
  </p>
</div>
