<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for(:title).presence || "DiveOps" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="DiveOps">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#F0F6FC">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= render "layouts/body_texture_styles" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-espuma antialiased text-abismo">
    <%# fixed: sticky falla si un padre tiene overflow oculto; el padding evita que el main quede bajo el nav. %>
    <nav class="app-site-nav flex flex-wrap items-center justify-between gap-x-4 gap-y-2 border-b border-abismo/30 px-5 py-1.5 text-sm shadow-md sm:flex-nowrap">
      <div class="flex min-w-0 min-h-0 flex-1 flex-wrap items-center gap-x-4 gap-y-2">
        <%= link_to root_path, class: "inline-flex shrink-0 items-center gap-2.5 no-underline transition hover:opacity-95" do %>
          <%= image_tag "logo2.png", alt: "", class: "h-24 w-auto shrink-0 nav-logo" %>
          <span class="text-lg font-semibold tracking-tight text-abismo">DiveOps</span>
        <% end %>
        <% if diver_signed_in? %>
          <%= link_to "Inicio", root_path, class: "text-abismo underline decoration-abismo/40 hover:text-oceano" %>
          <%= link_to "Catálogo", programs_path, class: "text-abismo underline decoration-abismo/40 hover:text-oceano" %>
        <% end %>
        <% if user_signed_in? %>
          <% if diver_signed_in? %>
            <span class="hidden text-arrecife/80 sm:inline" aria-hidden="true">|</span>
          <% end %>
          <% if super_admin? %>
            <%= link_to "Plataforma", admin_root_path, class: "text-profundo underline decoration-profundo/40 hover:text-oceano" %>
          <% end %>
          <% if current_agency.present? %>
            <%= render "shared/staff_nav_dropdown" %>
          <% end %>
        <% end %>
      </div>
      <% if diver_signed_in? || user_signed_in? %>
        <div class="flex w-full shrink-0 flex-wrap items-center justify-end gap-x-4 gap-y-2 sm:ml-auto sm:w-auto sm:justify-end">
          <% if diver_signed_in? %>
            <%= render "shared/diver_nav_dropdown" %>
          <% end %>
          <% if user_signed_in? %>
            <%= render "shared/user_nav_dropdown" %>
          <% end %>
        </div>
      <% end %>
      <% unless user_signed_in? || diver_signed_in? %>
        <div class="flex w-full flex-wrap items-center gap-x-4 gap-y-2 sm:ml-auto sm:w-auto sm:justify-end">
          <%= link_to "Inicio de sesión — buzo", new_diver_session_path, class: "text-abismo underline decoration-abismo/40 hover:text-oceano" %>
          <%= link_to "Inicio de sesión — staff de agencia", new_user_session_path, class: "text-abismo underline decoration-abismo/40 hover:text-oceano" %>
        </div>
      <% end %>
    </nav>

    <div class="relative z-0 pt-[7.5rem] sm:pt-[5.25rem]">
      <% flash.each do |key, message| %>
        <div
          class="container mx-auto mt-4 max-w-3xl px-5 text-sm <%= key == "alert" ? "rounded-xl border border-coral bg-coral/10 px-4 py-3 text-abismo" : "rounded-xl border border-oceano bg-arrecife/35 px-4 py-3 text-abismo" %>"
          role="status"
        >
          <%= message %>
        </div>
      <% end %>

      <main class="container mx-auto mt-8 px-5 pb-16">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
