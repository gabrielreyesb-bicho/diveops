<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for(:title).presence || "Plataforma · DiveOps" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= render "layouts/body_texture_styles" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-espuma antialiased text-abismo">
    <%= render "layouts/admin_nav" %>

    <div class="relative z-0 pt-[7.5rem] sm:pt-[5.25rem]">
      <% flash.each do |key, message| %>
        <div
          class="container mx-auto mt-4 max-w-3xl px-5 text-sm <%= key == "alert" ? "rounded-xl border border-coral bg-coral/10 px-4 py-3 text-abismo" : "rounded-xl border border-oceano bg-arrecife/35 px-4 py-3 text-abismo" %>"
          role="status"
        >
          <%= message %>
        </div>
      <% end %>

      <main class="container mx-auto mt-8 px-5 pb-16">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
