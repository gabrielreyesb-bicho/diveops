<%# locals: program, registration %>
<div class="rounded-xl border border-arrecife/50 bg-espuma/80 p-4 shadow-sm sm:p-5">
  <p class="text-sm font-semibold leading-snug text-profundo">
    <%= t("catalog.program_enrollment.heading.#{program.model_name.i18n_key}") %>
  </p>
  <p class="mt-2.5 text-sm text-abismo">
    <span class="text-abismo/70"><%= t("catalog.program_enrollment.status_caption") %>:</span>
    <span class="ml-1 inline-flex align-middle rounded-md px-2.5 py-1 text-xs font-medium <%= registration_status_badge_class(registration.status) %>">
      <%= t("catalog.program_enrollment.badge.#{registration.status}", default: registration_status_text(registration)) %>
    </span>
  </p>
  <p class="mt-2 text-xs leading-relaxed text-abismo/70">
    <%= t("catalog.program_enrollment.hint.#{registration.status}", default: "") %>
  </p>
</div>
