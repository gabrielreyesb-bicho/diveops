<%# locals: registration %>
<% return unless registration.present? %>
<% label = case registration.status.to_s
   when "confirmed" then "Inscripción confirmada"
   when "pending" then "Inscripción pendiente de confirmación"
   when "waitlisted" then "En lista de espera"
   when "cancelled" then "Inscripción cancelada"
   else "Inscripción"
   end %>
<% ic = "h-5 w-5 shrink-0 text-white drop-shadow-sm" %>
<span class="flex items-center justify-end" title="<%= label %>">
  <span class="pointer-events-none flex items-center justify-end" aria-hidden="true">
  <% case registration.status.to_s %>
  <% when "confirmed" %>
    <%# check in circle %>
    <svg class="<%= ic %>" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
  <% when "pending" %>
    <%# clock %>
    <svg class="<%= ic %>" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
  <% when "waitlisted" %>
    <%# queue / list %>
    <svg class="<%= ic %>" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" />
    </svg>
  <% when "cancelled" %>
    <%# círculo + aspa %>
    <svg class="<%= ic %>" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <circle cx="12" cy="12" r="9" />
      <path stroke-linecap="round" d="M15 9l-6 6M9 9l6 6" />
    </svg>
  <% else %>
    <svg class="<%= ic %>" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
    </svg>
  <% end %>
  </span>
  <span class="sr-only"><%= label %></span>
</span>
